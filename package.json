{
  "name": "dead-pixel-pet",
  "version": "1.1.0",
  "description": "A tiny pixel creature that lives on your desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac zip",
    "build:all": "electron-builder --win nsis --mac zip"
  },
  "author": "Yusuf Sina Uygunpolat",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.deadpixelpet.app",
    "productName": "Dead Pixel Pet",
    "icon": "assets/icon.png",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [{ "target": "zip", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment",
      "darkModeSupport": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ]
  }
}
